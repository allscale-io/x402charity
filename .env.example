# Required: Private key of the wallet that funds donations
DONATION_PRIVATE_KEY=0xabc123...

# Required: Wallet address of the charity receiving donations
CHARITY_WALLET=0xdef456...

# Optional: Display name for the charity (default: My Charity)
CHARITY_NAME=Give Directly

# Optional: Description of the charity
CHARITY_DESCRIPTION=Donations to Give Directly

# Optional: base (mainnet) or base-sepolia (testnet, default)
DONATION_NETWORK=base-sepolia

# Optional: Public URL of your server (auto-detected on Vercel)
BASE_URL=http://localhost:3402

# Optional: Server port (default: 3402)
PORT=3402
