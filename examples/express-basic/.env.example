# Server Configuration
PORT=3000

# x402charity Configuration

# Private key of the wallet that funds donations (with 0x prefix)
# WARNING: Never commit this to version control!
DONATION_PRIVATE_KEY=0x...

# The x402-gated donation endpoint URL
# Deploy your own server: https://github.com/allscale-io/x402charity
# Or use a public test endpoint if available
DONATE_ENDPOINT=https://your-x402charity-server.com/donate

# The charity receiving donations
# Example: Give Directly
CHARITY_NAME=Give Directly
CHARITY_WALLET=0x...  # The charity's wallet address
CHARITY_ID=give-directly

# Network: base (mainnet) or base-sepolia (testnet)
DONATION_NETWORK=base-sepolia

# Donation amount per request (default: $0.001)
DONATION_AMOUNT=$0.001
