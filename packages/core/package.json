    "viem": "^2.21.0"
  },
  "peerDependencies": {
    "express": "^4.0.0 || ^5.0.0",
    "next": ">=13.0.0"
  },
  "peerDependenciesMeta": {
    "express": { "optional": true },
    "next": { "optional": true }
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^25.3.3",
    "next": ">=13.0.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "x402", "charity", "donation", "micropayments", "usdc",
